# Define a base do Sgoinfre ou fallback local
SGOINFRE_BASE="$HOME/sgoinfre"
if [ -d "$SGOINFRE_BASE" ]; then
    # É boa prática usar o seu login no path do sgoinfre para evitar conflitos
    SGOINFRE="$SGOINFRE_BASE/$USER/hs_overlay"
else
    SGOINFRE="$(pwd)/.local"
fi

# --- Configurações do .NET ---
export DOTNET_ROOT="$SGOINFRE/.dotnet"
export NUGET_PACKAGES="$SGOINFRE/.nuget"
export DOTNET_CLI_HOME="$SGOINFRE/.dotnet_home"
export PATH="$DOTNET_ROOT:$DOTNET_ROOT/tools:$PATH"

# --- Configurações do GTK / Native Libs ---
# Define onde as bibliotecas compiladas pelo Makefile serão instaladas
export PREFIX="$SGOINFRE/local_libs"

# Faz o C# encontrar as libs (.so) em tempo de execução
export LD_LIBRARY_PATH="$PREFIX/lib/x86_64-linux-gnu:$PREFIX/lib:$LD_LIBRARY_PATH"

# Faz o compilador e ferramentas de build encontrarem as definições do GTK
export PKG_CONFIG_PATH="$PREFIX/lib/x86_64-linux-gnu/pkgconfig:$PREFIX/lib/pkgconfig:$PKG_CONFIG_PATH"

# Garante que os diretórios existam
mkdir -p "$DOTNET_ROOT" "$NUGET_PACKAGES" "$DOTNET_CLI_HOME" "$PREFIX"